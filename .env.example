# ===== 数据库配置 =====
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=coding_plan_manager
DB_PORT=5432

# ===== 服务端口 =====
FRONTEND_PORT=3000
BACKEND_PORT=8080

# ===== JWT 配置（生产环境务必修改） =====
JWT_ACCESS_SECRET=change-me-access-secret-in-prod
JWT_REFRESH_SECRET=change-me-refresh-secret-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ===== 加密密钥（32 字节 hex，生产环境务必修改） =====
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
