# ===== 生产环境配置 =====
# 复制到服务器: cp .env.production .env 并填写实际值

# ===== 数据库配置 =====
DB_USER=postgres
DB_PASSWORD=
DB_NAME=coding_plan_manager
DB_PORT=5432

# ===== JWT 配置 =====
# 生成方式: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ===== 加密密钥 =====
# 生成方式: openssl rand -hex 16
ENCRYPTION_KEY=
